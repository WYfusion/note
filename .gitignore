# 忽略临时上传/下载文件
.tmp.driveupload/
.tmp.drivedownload/

# Obsidian：先忽略全部，再按需放行可同步配置
.obsidian/*
!.obsidian/icons/
!.obsidian/themes/
!.obsidian/snippets/
!.obsidian/plugins/
!.obsidian/app.json
!.obsidian/appearance.json
!.obsidian/core-plugins.json
!.obsidian/community-plugins.json
!.obsidian/hotkeys.json
!.obsidian/canvas.json

# Obsidian：严格忽略会因浏览页面频繁变化的状态文件
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspaces.json
.obsidian/bookmarks.json
.obsidian/graph.json
.obsidian/backlink.json
.obsidian/page-preview.json
.obsidian/types.json
.obsidian/* (conflict *).json
.obsidian/plugins/recent-files-obsidian/
.trash/

# 忽略同步文件
sync.ffs_db

# 系统文件
.DS_Store
Thumbs.db

# 忽略大型二进制文件，如果有
*.mp4
*.mov
*.zip
*.rar
*.7z

